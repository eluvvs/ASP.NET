@{
    var pageKey = (string)ViewBag.PageKey;
    var comments = (List<Comment>)ViewBag.Comments;
    var notes = (List<Note>)ViewBag.Notes;
    bool isLoggedIn = (bool)ViewBag.IsLoggedIn;
    var currentUser = (string)ViewBag.CurrentUser;
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

@if (isLoggedIn)
{
    <!-- Floating Notes Button (bottom-right) -->
    <button class="notes-fab" id="notes-fab" title="Moje poznámky" onclick="document.getElementById('notes-panel').classList.toggle('open')">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
        </svg>
        @if (notes.Any())
        {
            <span class="notes-fab-badge">@notes.Count</span>
        }
    </button>

    <!-- Notes Overlay Panel -->
    <div class="notes-overlay" id="notes-panel">
        <div class="notes-panel-backdrop" onclick="document.getElementById('notes-panel').classList.remove('open')"></div>
        <div class="notes-panel-content">
            <div class="notes-panel-header">
                <h3>Moje poznámky</h3>
                <button class="notes-panel-close" onclick="document.getElementById('notes-panel').classList.remove('open')" title="Zavřít">✕</button>
            </div>
            <p class="notes-panel-hint">Soukromé poznámky k tomuto článku — vidíte je jen vy.</p>

            <form method="post" action="/Comment/AddNote" class="notes-panel-form">
                <input type="hidden" name="pageKey" value="@pageKey" />
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <textarea name="content" placeholder="Napište poznámku…" rows="2" required maxlength="2000"></textarea>
                <button type="submit">Přidat</button>
            </form>

            <div class="notes-panel-list">
                @if (notes.Any())
                {
                    @foreach (var note in notes)
                    {
                        <div class="notes-panel-item">
                            <span class="notes-panel-date">@note.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                            <p>@note.Content</p>
                            <form method="post" action="/Comment/DeleteNote" class="delete-form">
                                <input type="hidden" name="id" value="@note.Id" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit" class="btn-delete" title="Smazat">✕</button>
                            </form>
                        </div>
                    }
                }
                else
                {
                    <p class="empty-hint">Zatím žádné poznámky.</p>
                }
            </div>
        </div>
    </div>

    <!-- Comments Section (stays under article) -->
    <section class="interaction-section" id="comments-section">
        <h2>Komentáře</h2>
        <form method="post" action="/Comment/AddComment" class="interaction-form" enctype="multipart/form-data">
            <input type="hidden" name="pageKey" value="@pageKey" />
            <input type="hidden" name="returnUrl" value="@returnUrl" />
            <textarea name="content" placeholder="Napište komentář…" rows="3" required maxlength="2000"></textarea>
            <div class="comment-form-actions">
                <label class="comment-image-upload" title="Přiložit obrázek (max 5 MB)">
                    <input type="file" name="image" accept=".jpg,.jpeg,.png,.gif,.webp,.bmp" class="comment-image-input" />
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <polyline points="21 15 16 10 5 21"/>
                    </svg>
                    <span class="comment-image-label">Obrázek</span>
                </label>
                <span class="comment-image-name"></span>
                <button type="submit">Přidat komentář</button>
            </div>
        </form>

        @if (comments.Any())
        {
            <div class="interaction-list">
                @foreach (var comment in comments)
                {
                    <div class="interaction-card comment-card">
                        <div class="interaction-header">
                            <span class="interaction-user">@comment.Username</span>
                            <span class="interaction-date">@comment.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <p class="interaction-content">@comment.Content</p>
                        @if (!string.IsNullOrEmpty(comment.ImagePath))
                        {
                            <div class="comment-image-wrapper">
                                <a href="/uploads/comments/@comment.ImagePath" target="_blank" rel="noopener" class="comment-image-newtab" title="Otevřít v nové záložce">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                                        <polyline points="15 3 21 3 21 9"/>
                                        <line x1="10" y1="14" x2="21" y2="3"/>
                                    </svg>
                                    Otevřít originál
                                </a>
                                <img src="/uploads/comments/@comment.ImagePath"
                                     alt="Příloha komentáře"
                                     class="comment-image-thumb"
                                     onclick="this.classList.toggle('comment-image-expanded')" />
                            </div>
                        }
                        @if (comment.Username == currentUser)
                        {
                            <form method="post" action="/Comment/DeleteComment" class="delete-form">
                                <input type="hidden" name="id" value="@comment.Id" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit" class="btn-delete" title="Smazat">✕</button>
                            </form>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <p class="empty-hint">Zatím žádné komentáře. Buďte první!</p>
        }
    </section>
}
else
{
    <section class="interaction-section interaction-locked" id="login-prompt">
        <div class="lock-icon"></div>
        <p><a href="/User/Login">Přihlaste se</a> pro zobrazení a přidávání komentářů.</p>
    </section>
}

<script>
// Show selected image filename next to the upload button
document.querySelectorAll('.comment-image-input').forEach(function(input) {
    input.addEventListener('change', function() {
        var nameSpan = this.closest('.comment-form-actions').querySelector('.comment-image-name');
        if (this.files && this.files.length > 0) {
            nameSpan.textContent = this.files[0].name;
        } else {
            nameSpan.textContent = '';
        }
    });
});
</script>
