<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ASP.NET_MWC</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/style.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ASP.NET_MWC.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- Ikona uživatele — top right na každé stránce -->
    <div class="user-icon-wrapper">
        @if (Context.Session.GetString("Prihlasen") == "true")
        {
            <a href="/User/Profil" class="user-icon user-icon--logged-in" title="Můj profil">
                <img src="~/images/user-login.png" alt="Profil" />
            </a>
        }
        else
        {
            <a href="/User/Login" class="user-icon" title="Přihlásit se">
                <img src="~/images/user-login.png" alt="Přihlásit se" />
            </a>
        }
    </div>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
