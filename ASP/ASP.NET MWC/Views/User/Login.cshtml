@{
    ViewData["Title"] = "Přihlášení";
}

<div class="user-page">
    <h1>Přihlášení</h1>
    <p>Přihlaste se do svého účtu.</p>

    @if (TempData["Zprava"] != null)
    {
        <div class="zprava">@TempData["Zprava"]</div>
    }

    <form method="post" asp-controller="User" asp-action="Login">
        <div class="form-group">
            <label for="email">E-mail</label>
            <input type="email" id="email" name="email" placeholder="vas@email.cz" required />
        </div>

        <div class="form-group">
            <label for="heslo">Heslo</label>
            <input type="password" id="heslo" name="heslo" placeholder="Zadejte heslo" required />
        </div>

        <button type="submit">Přihlásit se</button>
    </form>

    <p class="link">Nemáte účet? <a href="/User/Register">Zaregistrujte se</a></p>
</div>
